{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jobarms-ingest",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": { "crons": ["7,37 * * * *"] },
  // Secrets (wrangler secret put): SUPABASE_URL, SUPABASE_SECRET_KEY,
  // INTERNAL_CRON_SECRET.
  "observability": {
    "enabled": true
  }
}
