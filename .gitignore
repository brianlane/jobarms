# Dependencies and builds
node_modules/
.next/
coverage/
dist/

# Runtime and logs
*.log
logs/
npm-debug.log*

# Env files — .env holds live secrets and must NEVER be committed
.env
.env.*
!.env.example

# OS and editor files
.DS_Store
.idea/
.cursor/
.vscode/*
!.vscode/extensions.json
*.sw?

# Supabase CLI temp files (auto-generated by `supabase link`, contain infra secrets)
supabase/.temp/
supabase/.branches
# NOTE: supabase/config.toml is TRACKED — it pins verify_jwt per edge function
# and CI's bulk `supabase functions deploy` must see those pins. It contains
# no secrets (project_id is public, it's in every Supabase URL).

# Cloudflare Workers local secrets
workers/**/.dev.vars
.wrangler/
workers/**/.wrangler/

# Misc
*.tsbuildinfo
.vercel
test-results/
