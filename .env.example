# JobArms environment — copy to .env (gitignored) and fill in.
# Local .env is the single source of truth; GitHub Actions secrets and Vercel
# env vars are set FROM these values (see README "CI/CD").

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (project settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...            # server-only, bypasses RLS
SUPABASE_DB_PASSWORD=                        # for CLI migrations (CI drift/deploy)
SUPABASE_ACCESS_TOKEN=sbp_...                # personal access token (CI supabase link)
# Legacy JWT-shaped keys (kept for tools that don't speak sb_* keys yet):
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_SECRET=

# --- Gemini (Google AI Studio "Job Arms" project, PAID tier) ---
GEMINI_API_KEY=

# --- Stripe (test mode until launch) ---
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...              # minted when the webhook endpoint is registered
STRIPE_PRICE_PREMIUM_MONTHLY=price_...       # created by scripts/oneshot/create-stripe-prices.ts

# --- Vercel (CI deploys; also set as GitHub Actions secrets) ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Internal shared secrets (generate: openssl rand -hex 32) ---
INTERNAL_CRON_SECRET=                        # auths cron/manual triggers -> internal endpoints
ARM_WORKER_SHARED_SECRET=                    # auths app <-> Cloudflare apply-arm worker

# --- Apply-arm worker location (set after the Phase 3 first deploy) ---
ARM_WORKER_URL=                              # e.g. https://jobarms-apply-arm.<account>.workers.dev

# --- Email (Phase 1) ---
RESEND_API_KEY=

# --- Cloudflare (Phase 3: worker deploys from CI) ---
CLOUDFLARE_API_TOKEN=
